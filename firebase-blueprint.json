{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Registered user profile details",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "Explanation": {
      "title": "Explanation Request",
      "description": "Custom user text explanations created from selected text",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "selectedText": { "type": "string" },
        "explanationText": { "type": "string" },
        "audioBase64": { "type": "string" },
        "videoOperationName": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "selectedText", "explanationText", "createdAt"]
    },
    "Chat": {
      "title": "Chat Thread",
      "description": "Multi-turn chat history for study and simulation",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "messages": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "messages", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile collection"
    },
    "/explanations/{explanationId}": {
      "schema": "Explanation",
      "description": "Explanations generated by context menu selections"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat threads with Gemini for consulting"
    }
  }
}
